    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "styled-components": "^6.3.11",
    "xlsx": "^0.18.5"
